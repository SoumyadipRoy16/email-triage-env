# ─────────────────────────────────────────────────────────────
# Email Triage OpenEnv — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# REQUIRED — The OpenAI-compatible API endpoint for your LLM
# Examples:
#   Anthropic : https://api.anthropic.com/v1
#   OpenAI    : https://api.openai.com/v1
#   Together  : https://api.together.xyz/v1
API_BASE_URL=https://router.huggingface.co/v1

# REQUIRED — The model identifier to use for inference
# Examples:
#   claude-sonnet-4-20250514
#   gpt-4o
#   meta-llama/Llama-3.1-8B-Instruct:cerebras
MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct:cerebras

# REQUIRED — Your Hugging Face token / API key
# Used both for HF Space deployment and as the LLM API key
HF_TOKEN=hf_your_token_here

# OPTIONAL — Email Triage environment server URL (for inference.py)
# Default: http://localhost:8000
# For HF Spaces, set this to your Space URL:
# ENV_BASE_URL=https://your-username-email-triage-env.hf.space
ENV_BASE_URL=http://localhost:8000

# OPTIONAL — LLM inference settings
TEMPERATURE=0.2
MAX_TOKENS=2048
MAX_RETRIES=2
